<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>缺課管理 Ultimate</title>

<style>
:root {
    --bg:#f2f4f8;
    --card:#fff;
    --text:#111;
    --primary:#007aff;
    --danger:#ff3b30;
}
@media (prefers-color-scheme: dark){
:root{
    --bg:#000;
    --card:#1c1c1e;
    --text:#fff;
}
}
body{
    margin:0;
    font-family:-apple-system;
    background:var(--bg);
    color:var(--text);
}
.container{padding:20px;}
.card{
    background:var(--card);
    padding:16px;
    border-radius:16px;
    margin-bottom:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.05);
}
h1{font-size:22px;margin-bottom:10px;}
select,input,button{
    width:100%;
    padding:12px;
    border-radius:12px;
    border:none;
    font-size:16px;
    margin-top:8px;
}
button{background:var(--primary);color:white;}
.progress{height:8px;background:#ddd;border-radius:10px;margin-top:10px;}
.bar{height:100%;width:0;background:var(--primary);border-radius:10px;}
.danger .bar{background:var(--danger);}
.item{display:flex;justify-content:space-between;margin:5px 0;}
.small{font-size:13px;color:gray;}
.del{color:red;cursor:pointer;}
</style>
</head>

<body>
<div class="container">

<h1>📚 缺課管理 Ultimate</h1>

<div class="card">
<div class="small">📆 今日課程</div>
<div id="today"></div>
</div>

<div class="card">
<select id="course"></select>
<button onclick="addAbsent()">缺課 +1</button>
<div class="progress"><div class="bar" id="bar"></div></div>
<div id="result"></div>
</div>

<div class="card">
<div class="small">✏️ 補登缺課</div>
<input type="date" id="date">
<select id="course2"></select>
<button onclick="addManual()">新增紀錄</button>
</div>

<div class="card">
<div class="small">📊 排行榜</div>
<div id="rank"></div>
</div>

<div class="card">
<div class="small">📅 詳細紀錄</div>
<div id="history"></div>
</div>

</div>

<script>
const schedule={
1:["微積分導論（二）","微積分導論（二）","英文閱讀與寫作","體育","數學甲","語文表達與傳播應用","悅讀樂科學（二）"],
2:["彈性學習時間","英語聽講","數學甲","選修物理－電磁現象二與量子現象","藝術生活","各類文學選讀","各類文學選讀"],
3:["語文表達與傳播應用","數學甲","選修化學－化學反應與平衡二","英文閱讀與寫作","未來想像與生涯進路","體育","選修物理－電磁現象二與量子現象"],
4:["英語聽講","選修化學－化學反應與平衡二","領域課程：機器人專題","領域課程：機器人專題","數學甲","領域課程：科技應用專題","選修物理－波動、光及聲音"],
5:["彈性學習時間","家政","多元體育課程（二）","選修化學－有機化學與應用科技","團體活動時間","團體活動時間","團體活動時間"]
};

const courses=[...new Set(Object.values(schedule).flat())];

let records=JSON.parse(localStorage.getItem("records")||"[]");

let sel=document.getElementById("course");
let sel2=document.getElementById("course2");

courses.forEach(c=>{
let o=document.createElement("option");
o.text=c;
sel.add(o);
sel2.add(o.cloneNode(true));
});

function todayCourse(){
let d=new Date().getDay();
if(d===0||d===6)return "今天沒課 😎";
return schedule[d].join("、");
}
document.getElementById("today").innerText=todayCourse();

function addAbsent(){
let c=sel.value;
let date=new Date().toLocaleDateString();
records.push({c,date});
save();
updateUI(c);
}

function addManual(){
let c=sel2.value;
let date=document.getElementById("date").value;
if(!date)return alert("請選日期");
records.push({c,date});
save();
updateUI(c);
}

function save(){
localStorage.setItem("records",JSON.stringify(records));
}

function getCount(c){
return records.filter(r=>r.c===c).length;
}

function getTotal(c){
if(c==="數學甲")return 56;
if(c==="團體活動時間")return 42;
return 28;
}

function updateUI(c){
let count=getCount(c);
let total=getTotal(c);
let rate=count/total;

document.getElementById("result").innerText=
`${c}：${count}/${total} (${(rate*100).toFixed(1)}%)`;

document.getElementById("bar").style.width=(rate*100)+"%";

updateRank();
updateHistory();
}

function updateRank(){
let map={};
records.forEach(r=>{
map[r.c]=(map[r.c]||0)+1;
});

let arr=Object.entries(map).sort((a,b)=>b[1]-a[1]);
let html="";
arr.forEach(([c,v])=>{
html+=`<div class="item"><span>${c}</span><span>${v}</span></div>`;
});
document.getElementById("rank").innerHTML=html||"尚無資料";
}

function del(i){
records.splice(i,1);
save();
updateRank();
updateHistory();
}

function updateHistory(){
let html="";
records.slice().reverse().forEach((r,i)=>{
html+=`<div class="item">
<span>${r.date} - ${r.c}</span>
<span class="del" onclick="del(${records.length-1-i})">刪除</span>
</div>`;
});
document.getElementById("history").innerHTML=html||"尚無紀錄";
}

updateRank();
updateHistory();
</script>

</body>
</html>
